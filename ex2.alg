algoritmo "semnome"
// Funçăo :
// Autor :
// Data : 16/03/2026
// Seçăo de Declaraçőes 
var
p1, p2, p3,m:real
n:caracter
inicio
escreval("escreva seu nome: ")
leia(n)
escreval("valor da primeira prova: ")
leia(p1)
escreval("valor da segunda prova: ")
leia(p2)
escreval("valor da terceira prova: ")
leia(p3)
m<- (p1+p2+p3)/3
escreval("a média de ",n," é: ",m)
fimalgoritmo
