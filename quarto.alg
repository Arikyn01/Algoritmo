algoritmo "semnome"
// Funçăo :
// Autor :
// Data : 16/03/2026
// Seçăo de Declaraçőes 
var
a,b,c,d:real
inicio
escreval("escreva o valor do raio: ")
leia(a)
escreval("escreva o valor da altura: ")
leia(b)
c<- 3.14
escreval("o valor de PI é: ", c)
d<-(a^2) * b * c
escreval("o valor do volume é: ",d)
fimalgoritmo
